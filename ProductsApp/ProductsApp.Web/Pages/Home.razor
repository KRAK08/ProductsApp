<!-- Contacto -->
<section id="contacto" class="py-5">
    <div class="py-5 container">
        <div class="row justify-content-center mb-5 text-center">
            <div class="col-lg-8">
                <h2 class="fw-bold mb-3">Contáctanos</h2>
                <p class="text-muted">Completa el formulario y nos pondremos en contacto contigo</p>
            </div>
        </div>
        <div class="row g-4">
            <div class="col-lg-6">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body p-4 p-md-5">
                        <form>
                            <div class="mb-3">
                                <label for="nombre" class="form-label">Nombre completo</label>
                                <input type="text" class="form-control" id="nombre" required>
                            </div>
                            <div class="mb-3">
                                <label for="email" class="form-label">Correo electrónico</label>
                                <input type="email" class="form-control" id="email" required>
                            </div>
                            <div class="mb-3">
                                <label for="telefono" class="form-label">Teléfono</label>
                                <input type="tel" class="form-control" id="telefono">
                            </div>
                            <div class="mb-3">
                                <label for="mensaje" class="form-label">Mensaje</label>
                                <textarea class="form-control" id="mensaje" rows="4" required></textarea>
                            </div>
                            <button type="submit" class="btn btn-primary w-100">Enviar Mensaje</button>
                        </form>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body p-4 p-md-5">
                        <h4 class="fw-bold mb-4">Información de contacto</h4>
                        <div class="d-flex mb-4">
                            <div class="me-4 text-primary">
                                <i class="bi bi-geo-alt fs-3"></i>
                            </div>
                            <div>
                                <h5 class="fw-bold">Dirección</h5>
                                <p class="text-muted mb-0">Av. Principal 1234, Ciudad, País</p>
                            </div>
                        </div>
                        <div class="d-flex mb-4">
                            <div class="me-4 text-primary">
                                <i class="bi bi-telephone fs-3"></i>
                            </div>
                            <div>
                                <h5 class="fw-bold">Teléfono</h5>
                                <p class="text-muted mb-0">+1 234 567 890</p>
                            </div>
                        </div>
                        <div class="d-flex mb-4">
                            <div class="me-4 text-primary">
                                <i class="bi bi-envelope fs-3"></i>
                            </div>
                            <div>
                                <h5 class="fw-bold">Email</h5>
                                <p class="text-muted mb-0">info@techsolutions.com</p>
                            </div>
                        </div>
                        <div class="mt-5">
                            <h5 class="fw-bold mb-3">Síguenos</h5>
                            <a href="#" class="text-dark me-3"><i class="bi bi-facebook fs-3"></i></a>
                            <a href="#" class="text-dark me-3"><i class="bi bi-twitter fs-3"></i></a>
                            <a href="#" class="text-dark me-3"><i class="bi bi-linkedin fs-3"></i></a>
                            <a href="#" class="text-dark"><i class="bi bi-instagram fs-3"></i></a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

